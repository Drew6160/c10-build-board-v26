    {
      "id": "mdb_battery",
      "type": "distribution",
      "tier": 1,
      "zone": "B",
      "label": "MDB Fuse Block — Battery",
      "load": 0,
      "partNumber": "Littelfuse 04980933.X",
      "notes": "3-pole sealed MIDI PDM. IP67/IP69K. Mounted near behind-the-cab battery on passenger side. Internally bussed 4 AWG input. Pole 1: ECM direct feed 40A. Pole 2: Heated seat relay 30A. Pole 3: Bowler T56 module 20A."
