    },
    {
      "id": "estopp_mod_disconnect",
      "type": "connector",
      "tier": 1,
      "zone": "B",
      "label": "E-Stopp Module Disconnect",
      "load": 0,
      "partNumber": "Deutsch DT 4-way",
      "notes": "Service disconnect at panel — allows E-Stopp module removal without disturbing panel wiring. DT 4-way — power, ground, button signal, button ground."
    },
    {
      "id": "estopp",
      "type": "control",
      "tier": 1,
      "zone": "B",
      "label": "E-Stopp Module",
      "load": 5,
      "partNumber": "E-Stopp",
      "notes": "Electric parking brake actuator control module. Mounted under-seat panel, passenger side front zone. Electrical only — no hydraulic fittings on module. Powered via estopp_pwr_disconnect (battery junction isolation) and estopp_mod_disconnect (panel service disconnect) in series. Button wire runs forward to dash/console — exact switch location still TBD, separate from Ring Brothers dash bezel switch panel. E-Stopp wiring isolated from Holley ECU power path. Retained as a module node (not just disconnect connectors) due to ENDO CVT reliability history that may require future rewiring."
    }
