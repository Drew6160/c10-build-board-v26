    {
      "id": "mdb_rear",
      "type": "distribution",
      "tier": 1,
      "zone": "C",
      "label": "MDB Fuse Block — Rear",
      "load": 0,
      "partNumber": "Littelfuse 04980933.X",
      "notes": "3-pole sealed MIDI PDM. IP67/IP69K. Mounted on rear electronics plate adjacent to C105 controller. Fed via 4 AWG short run from behind-the-cab battery. Pole 1: Accuair ENDO CVT 50A. Pole 2: DW810 fuel pump controller 30A. Pole 3: Spare — sealed with cavity plug for future expansion."
    },
    {
      "id": "estopp_pwr_disconnect",
      "type": "connector",
      "tier": 1,
      "zone": "B",
      "label": "E-Stopp Power Disconnect",
      "load": 0,
      "partNumber": "Deutsch DT 2-way",
