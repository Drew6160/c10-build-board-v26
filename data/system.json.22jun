      "tier": 1,
      "zone": "B",
      "label": "Vintage Air HVAC",
      "load": 15,
      "partNumber": "Vintage Air Gen 5",
      "notes": "491210-RUA ProLine 3-knob horizontal control. Requires 246404 ECU. Refrigerant lines route under fender — not through firewall. Mounted in anodized black billet center dash bezel — see center_dash_disconnect_hvac for service connector."
    },
    {
      "id": "center_dash_disconnect_radio",
      "type": "connector",
      "tier": 1,
      "zone": "B",
      "label": "Center Dash Disconnect — Radio",
      "load": 0,
      "partNumber": "Deutsch DT 8-pin",
      "notes": "Service disconnect at base of center dash sub-frame, in the 5in service pocket behind the bezel. Covers Kenwood DMX958XR power/ground/illum/VSS only — separate from HVAC disconnect so radio can be pulled without disturbing A/C wiring. Allows full bezel removal without cutting cab wiring."
    },
    {
      "id": "center_dash_disconnect_hvac",
      "type": "connector",
      "tier": 1,
      "zone": "B",
      "label": "Center Dash Disconnect — HVAC",
      "load": 0,
      "partNumber": "Deutsch DT 8-pin",
      "notes": "Service disconnect at base of center dash sub-frame, in the 5in service pocket behind the bezel. Covers Vintage Air 491210-RUA control head only — separate from radio disconnect for independent serviceability. Allows full bezel removal without cutting cab wiring."
    },
    {
      "id": "radio",
      "type": "accessory",
      "tier": 1,
      "zone": "B",
      "label": "Kenwood DMX958XR",
      "load": 5,
      "partNumber": "Kenwood DMX958XR",
      "notes": "Wireless CarPlay/Android Auto. 6-ch 5V preouts. USB-C. HDMI input. 720p HD screen, LDAC, HD camera support. Same 3.3in chassis depth as DMX908S — no fitment change. Pink VSS input wired to second independent Bowler speed output for dead-reckoning nav when GPS signal is poor. Mounted in anodized black billet center dash bezel — see center_dash_disconnect for service connector."
    },
    {
      "id": "fuel_relay",
